---
/**
 * English Blog Post Detail Page
 * Dynamic route for individual blog posts
 */
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDate, getBlogPosts } from '@utils/content';
import { generateBlogPostSchema } from '@utils/seo';
import type { SEOMeta } from '@/types/index';

export async function getStaticPaths() {
  const posts = await getBlogPosts('en');

  return posts.map((postEntry) => ({
    params: { slug: postEntry.data.slug },
    props: { post: postEntry },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get all posts for navigation (already sorted by date, newest first)
const sortedPosts = await getBlogPosts('en');
const currentIndex = sortedPosts.findIndex((p) => p.data.slug === post.data.slug);
const previousPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// SEO metadata
const meta: SEOMeta = {
  title: post.data.title,
  description: post.data.description,
  keywords: post.data.tags,
  locale: 'en',
  type: 'article',
  publishedTime: post.data.date.toISOString(),
  modifiedTime: post.data.updatedDate?.toISOString(),
  tags: post.data.tags,
  image: post.data.coverImage,
  imageAlt: post.data.coverAlt,
};

// Structured data
const blogPostSchema = generateBlogPostSchema(
  post.data.title,
  post.data.description,
  post.data.date,
  post.data.updatedDate,
  post.data.coverImage,
  Astro.url.href,
  'en',
);
---

<BaseLayout meta={meta} locale="en">
  <article class="blog-post">
    <div class="container">
      <!-- Article Header -->
      <header class="post-header">
        <div class="post-meta">
          <time class="post-date" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date, 'en')}
          </time>
          {post.data.updatedDate && (
            <span class="post-updated">
              · Updated {formatDate(post.data.updatedDate, 'en')}
            </span>
          )}
        </div>

        <h1 class="post-title">{post.data.title}</h1>

        <p class="post-description">{post.data.description}</p>

        {post.data.tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {post.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}
      </header>

      <!-- Article Content -->
      <div class="post-content">
        <Content />
      </div>

      <!-- Article Footer -->
      <footer class="post-footer">
        <div class="post-footer__inner">
          <p class="post-footer__text">
            Thanks for reading! If you found this helpful, feel free to share it with others.
          </p>

          {post.data.tags.length > 0 && (
            <div class="post-footer__tags">
              <h2 class="post-footer__heading">Tagged with:</h2>
              <ul class="tag-list">
                {post.data.tags.map((tag) => (
                  <li class="tag tag--large">{tag}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </footer>

      <!-- Post Navigation -->
      {(previousPost || nextPost) && (
        <nav class="post-navigation" aria-label="Post navigation">
          <h2 class="visually-hidden">Navigate to other posts</h2>
          <div class="post-navigation__grid">
            {previousPost ? (
              <a href={`/en/blog/${previousPost.data.slug}/`} class="post-nav-card post-nav-card--prev">
                <span class="post-nav-card__label">← Previous Post</span>
                <span class="post-nav-card__title">{previousPost.data.title}</span>
              </a>
            ) : (
              <div></div>
            )}

            {nextPost && (
              <a href={`/en/blog/${nextPost.data.slug}/`} class="post-nav-card post-nav-card--next">
                <span class="post-nav-card__label">Next Post →</span>
                <span class="post-nav-card__title">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}

      <!-- Back to Blog -->
      <div class="back-link">
        <a href="/en/blog/" class="button button--outline">
          ← Back to All Posts
        </a>
      </div>
    </div>
  </article>

  <!-- Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
</BaseLayout>

<style>
  .blog-post {
    width: 100%;
    padding: var(--space-2xl) 0;
  }

  .container {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  /* Post Header */
  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .post-date {
    font-weight: var(--font-weight-medium);
  }

  .post-updated {
    color: var(--color-text-secondary);
  }

  .post-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .post-description {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  /* Tags */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: var(--space-md) 0 0;
  }

  .tag {
    display: inline-block;
    padding: var(--space-2xs) var(--space-sm);
    background-color: var(--color-accent-light);
    color: var(--color-accent-primary);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .tag--large {
    font-size: var(--font-size-base);
    padding: var(--space-xs) var(--space-md);
  }

  /* Post Content */
  .post-content {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-primary);
  }

  .post-content :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    line-height: var(--line-height-tight);
  }

  .post-content :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    line-height: var(--line-height-tight);
  }

  .post-content :global(h4) {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .post-content :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--color-bg-tertiary);
    padding: 0.125rem 0.25rem;
    border-radius: var(--radius-sm);
  }

  .post-content :global(pre) {
    background-color: var(--color-bg-tertiary);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .post-content :global(pre code) {
    background-color: transparent;
    padding: 0;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent-primary);
    padding-left: var(--space-md);
    margin-left: 0;
    margin-bottom: var(--space-md);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* Post Footer */
  .post-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .post-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .post-footer__text {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post-footer__heading {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  /* Post Navigation */
  .post-navigation {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .post-navigation__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .post-nav-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .post-nav-card:hover {
    background-color: var(--color-bg-tertiary);
    border-color: var(--color-accent-primary);
    transform: translateY(-2px);
  }

  .post-nav-card--next {
    text-align: right;
  }

  .post-nav-card__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-primary);
  }

  .post-nav-card__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  /* Back Link */
  .back-link {
    margin-top: var(--space-xl);
    text-align: center;
  }

  /* Button */
  .button {
    display: inline-block;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .button--outline {
    background-color: transparent;
    color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
  }

  .button--outline:hover {
    background-color: var(--color-accent-light);
  }

  /* Visually Hidden */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .blog-post {
      padding: var(--space-xl) 0;
    }

    .post-title {
      font-size: var(--font-size-3xl);
    }

    .post-description {
      font-size: var(--font-size-lg);
    }

    .post-content {
      font-size: var(--font-size-base);
    }

    .post
