---
/**
 * English Project Detail Page
 * Dynamic route for individual projects
 */
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDate, getProjects } from '@utils/content';
import type { SEOMeta } from '@/types/index';

export async function getStaticPaths() {
  const projects = await getProjects('en');

  return projects.map((projectEntry) => ({
    params: { slug: projectEntry.data.slug },
    props: { project: projectEntry },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);

// Get all projects for navigation (already sorted by date, newest first)
const sortedProjects = await getProjects('en');
const currentIndex = sortedProjects.findIndex((p) => p.data.slug === project.data.slug);
const previousProject = currentIndex < sortedProjects.length - 1 ? sortedProjects[currentIndex + 1] : null;
const nextProject = currentIndex > 0 ? sortedProjects[currentIndex - 1] : null;

// SEO metadata
const meta: SEOMeta = {
  title: project.data.title,
  description: project.data.summary,
  keywords: project.data.tags,
  locale: 'en',
  type: 'website',
  image: project.data.coverImage,
  imageAlt: project.data.coverAlt,
};
---

<BaseLayout meta={meta} locale="en">
  <article class="project-detail">
    <div class="container">
      <!-- Project Header -->
      <header class="project-header">
        <div class="project-meta">
          <time datetime={project.data.date.toISOString()}>
            {formatDate(project.data.date, 'en')}
          </time>
          <span class={`status status--${project.data.status}`}>
            {project.data.status}
          </span>
        </div>

        <h1 class="project-title">{project.data.title}</h1>

        <p class="project-summary">{project.data.summary}</p>

        {project.data.tags.length > 0 && (
          <ul class="tag-list" aria-label="Technologies used">
            {project.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}

        {(project.data.url || project.data.repository) && (
          <div class="project-links">
            {project.data.url && (
              <a
                href={project.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="button button--primary"
              >
                View Live Site ↗
              </a>
            )}
            {project.data.repository && (
              <a
                href={project.data.repository}
                target="_blank"
                rel="noopener noreferrer"
                class="button button--secondary"
              >
                View Source Code ↗
              </a>
            )}
          </div>
        )}
      </header>

      <!-- Project Content -->
      <div class="project-content">
        <Content />
      </div>

      <!-- Project Footer -->
      <footer class="project-footer">
        <div class="project-footer__inner">
          {project.data.tags.length > 0 && (
            <div class="project-footer__tags">
              <h2 class="project-footer__heading">Technologies & Tools:</h2>
              <ul class="tag-list">
                {project.data.tags.map((tag) => (
                  <li class="tag tag--large">{tag}</li>
                ))}
              </ul>
            </div>
          )}

          {(project.data.url || project.data.repository) && (
            <div class="project-footer__links">
              <h2 class="project-footer__heading">Links:</h2>
              <div class="link-group">
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link link--external"
                  >
                    Live Site ↗
                  </a>
                )}
                {project.data.repository && (
                  <a
                    href={project.data.repository}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link link--external"
                  >
                    Source Code ↗
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </footer>

      <!-- Project Navigation -->
      {(previousProject || nextProject) && (
        <nav class="project-navigation" aria-label="Project navigation">
          <h2 class="visually-hidden">Navigate to other projects</h2>
          <div class="project-navigation__grid">
            {previousProject ? (
              <a href={`/en/projects/${previousProject.data.slug}/`} class="project-nav-card project-nav-card--prev">
                <span class="project-nav-card__label">← Previous Project</span>
                <span class="project-nav-card__title">{previousProject.data.title}</span>
              </a>
            ) : (
              <div></div>
            )}

            {nextProject && (
              <a href={`/en/projects/${nextProject.data.slug}/`} class="project-nav-card project-nav-card--next">
                <span class="project-nav-card__label">Next Project →</span>
                <span class="project-nav-card__title">{nextProject.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}

      <!-- Back to Projects -->
      <div class="back-link">
        <a href="/en/projects/" class="button button--outline">
          ← Back to All Projects
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    width: 100%;
    padding: var(--space-2xl) 0;
  }

  .container {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  /* Project Header */
  .project-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    flex-wrap: wrap;
  }

  .project-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .project-summary {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  /* Status Badge */
  .status {
    display: inline-block;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: capitalize;
  }

  .status--active {
    background-color: hsl(142, 71%, 95%);
    color: var(--color-success);
  }

  .status--completed {
    background-color: hsl(217, 91%, 95%);
    color: var(--color-accent-primary);
  }

  .status--archived {
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
  }

  /* Tags */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: var(--space-md) 0 0;
  }

  .tag {
    display: inline-block;
    padding: var(--space-2xs) var(--space-sm);
    background-color: var(--color-accent-light);
    color: var(--color-accent-primary);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .tag--large {
    font-size: var(--font-size-base);
    padding: var(--space-xs) var(--space-md);
  }

  /* Project Content */
  .project-content {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-primary);
  }

  .project-content :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    line-height: var(--line-height-tight);
  }

  .project-content :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    line-height: var(--line-height-tight);
  }

  .project-content :global(h4) {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .project-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .project-content :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .project-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .project-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--color-bg-tertiary);
    padding: 0.125rem 0.25rem;
    border-radius: var(--radius-sm);
  }

  .project-content :global(pre) {
    background-color: var(--color-bg-tertiary);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .project-content :global(pre code) {
    background-color: transparent;
    padding: 0;
  }

  .project-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
  }

  .project-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* Project Footer */
  .project-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .project-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .project-footer__heading {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .link-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Project Navigation */
  .project-navigation {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .project-navigation__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .project-nav-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .project-nav-card:hover {
    background-color: var(--color-bg-tertiary);
    border-color: var(--color-accent-primary);
    transform: translateY(-2px);
  }

  .project-nav-card--next {
    text-align: right;
  }

  .project-nav-card__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-primary);
  }

  .project-nav-card__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  /* Back Link */
  .back-link {
    margin-top: var(--space-xl);
    text-align: center;
  }

  /* Links */
  .link {
    color: var(--color-accent-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
  }

  .link:hover {
    text-decoration: underline;
  }

  .link--external {
    font-size: var(--font-size-base);
  }

  /* Buttons */
  .button {
    display: inline-block;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .button--primary {
    background-color: var(--color-accent-primary);
    color: var(--color-text-inverse);
  }

  .button--primary:hover {
    background-color: var(--color-accent-hover);
  }

  .button--secondary {
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    border-color: var(--color-border);
  }

  .button--secondary:hover {
    background-color: var(--color-bg-secondary);
  }

  .button--outline {
    background-color: transparent;
    color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
  }

  .button--outline:hover {
    background-color: var(--color-accent-light);
  }

  /* Visually Hidden */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .project-detail {
      padding: var(--space-xl) 0;
    }

    .project-title {
      font-size: var(--font-size-3xl);
    }

    .project
