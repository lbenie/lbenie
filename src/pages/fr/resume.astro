---
/**
 * French Print-Optimized Resume/CV Page
 * Designed for printing to PDF - visit /fr/resume and press Ctrl+P
 */
import { getExperience, formatDateShort, formatDuration } from '@utils/content';

// Fetch all English experience entries (sorted by order and date)
const experiences = await getExperience('fr');

// Calculate total years of experience (starting from 2014)
const startYear = 2014;
const currentYear = new Date().getFullYear();
const yearsOfExperience = currentYear - startYear;

// Extract unique technologies from all experiences
const allTechnologies = new Set<string>();
for (const exp of experiences) {
  if (exp.data.stack) {
    for (const tech of exp.data.stack) {
      allTechnologies.add(tech);
    }
  }
}

// Core skills organized by category
const skills = {
  frontend: ['React', 'TypeScript', 'JavaScript', 'Angular', 'Vue.js', 'HTML/CSS'],
  backend: ['Node.js', 'Ruby on Rails', 'GraphQL', 'REST APIs', 'Microservices'],
  tools: ['Git', 'Docker', 'CI/CD', 'AWS', 'Agile/Scrum'],
  ai: ['Intégration IA', 'Cursor', 'GitHub Copilot', 'Claude']
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lucien Bénié - CV</title>
  <meta name="description" content="CV de Lucien Bénié - Développeur Staff fullstack">
  <meta name="robots" content="noindex, nofollow">
  <style>
    /* Reset and base styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      font-size: 9pt;
      line-height: 1.2;
      color: #1a1a1a;
      background: #ffffff;
      max-width: 8.5in;
      margin: 0 auto;
      padding: 0.4in;
      position: relative;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 2px solid #1a1a1a;
    }

    .header h1 {
      font-size: 20pt;
      font-weight: 700;
      margin-bottom: 2px;
      letter-spacing: -0.5px;
    }

    .header .title {
      font-size: 11pt;
      font-weight: 600;
      color: #4a4a4a;
      margin-bottom: 6px;
    }

    .contact-info {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      font-size: 8pt;
      color: #4a4a4a;
    }

    .contact-info a {
      color: #2563eb;
      text-decoration: none;
    }

    .contact-info svg {
      display: inline-block;
      vertical-align: middle;
      margin-right: 2px;
      color: #4a4a4a;
    }

    /* Section headings */
    .section {
      margin-bottom: 10px;
      page-break-inside: avoid;
    }

    .section-title {
      font-size: 12pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 5px;
      padding-bottom: 2px;
      border-bottom: 1.5px solid #1a1a1a;
    }

    /* Professional summary */
    .summary {
      font-size: 8.5pt;
      line-height: 1.3;
      text-align: justify;
    }

    /* Experience entries */
    .experience-item {
      margin-bottom: 8px;
      page-break-inside: avoid;
    }

    .experience-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 2px;
    }

    .experience-role {
      font-size: 10pt;
      font-weight: 700;
      color: #1a1a1a;
    }

    .experience-date {
      font-size: 8pt;
      color: #4a4a4a;
      white-space: nowrap;
    }

    .experience-company {
      font-size: 9pt;
      font-weight: 600;
      color: #2563eb;
      margin-bottom: 1px;
    }

    .experience-location {
      font-size: 8pt;
      color: #6a6a6a;
      margin-bottom: 3px;
    }

    .experience-description {
      display: none;
    }

    .experience-highlights {
      margin-top: 3px;
    }

    .experience-highlights ul {
      margin-left: 16px;
      list-style-type: disc;
    }

    .experience-highlights li {
      font-size: 8.5pt;
      line-height: 1.3;
      margin-bottom: 2px;
      text-align: justify;
    }

    .experience-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 4px;
    }

    .tech-tag {
      display: inline-block;
      padding: 1px 6px;
      background: #f3f4f6;
      border: 1px solid #d1d5db;
      border-radius: 3px;
      font-size: 7.5pt;
      font-weight: 500;
      color: #4a4a4a;
    }

    /* Skills section */
    .skills-list {
      font-size: 8.5pt;
      line-height: 1.3;
      color: #4a4a4a;
    }

    /* Education and Languages side by side */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .one-liner {
      font-size: 8.5pt;
      line-height: 1.3;
      color: #4a4a4a;
    }

    /* Copyright footer */
    .copyright {
      text-align: center;
      font-size: 7pt;
      color: #9ca3af;
      margin-top: 16px;
      padding-top: 8px;
    }

    /* Action buttons - ONLY visible on screen */
    @media screen {
      .print-actions {
        position: fixed;
        top: 20px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 8.5in;
        margin: 0 auto;
        padding: 0 0.5in;
        z-index: 1000;
        pointer-events: none;
      }

      .print-actions > * {
        pointer-events: auto;
      }

      .print-actions-group {
        display: flex;
        gap: 8px;
      }

      .print-button, .lang-button {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: all 0.2s;
        text-decoration: none;
      }

      .print-button {
        background: #2563eb;
        color: white;
      }

      .print-button:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15);
      }

      .print-button:active {
        transform: translateY(0);
      }

      .lang-button {
        background: transparent;
        color: #2563eb;
        border: 2px solid #2563eb;
      }

      .lang-button:hover {
        background: #eff6ff;
        transform: translateY(-2px);
        box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15);
      }

      .lang-button:active {
        transform: translateY(0);
      }
    }

    /* Print styles - completely remove buttons from existence */
    @media print {
      @page {
        size: letter;
        margin: 0.4in;
      }

      body {
        margin: 0;
        padding: 0;
        max-width: 100%;
        font-size: 9pt;
        height: auto !important;
        page-break-after: avoid;
        break-after: avoid;
      }

      .print-actions {
        display: none !important;
        visibility: hidden !important;
        position: absolute !important;
        left: -9999px !important;
        width: 0 !important;
        height: 0 !important;
        overflow: hidden !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      .section {
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .experience-item {
        page-break-inside: avoid;
        break-inside: avoid;
      }

      a {
        color: #1a1a1a;
        text-decoration: none;
      }

      .contact-info a::after {
        content: "";
      }

      .copyright {
        margin-top: 8px;
        padding-top: 4px;
        page-break-before: avoid;
        page-break-after: avoid;
        page-break-inside: avoid;
        break-before: avoid;
        break-after: avoid;
        break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <h1>Lucien Bénié</h1>
    <div class="title">Développeur logiciel Staff fullstack</div>
    <div class="contact-info">
      <span><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg> Sherbrooke, QC, Canada</span>
      <span><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> <a href="https://lbenie.me">lbenie.me</a></span>
      <span><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zM6.447 20.452H3.694V9h3.554zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg> <a href="https://linkedin.com/in/lbenie">linkedin.com/in/lbenie</a></span>
      <span><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg> <a href="https://github.com/lbenie">github.com/lbenie</a></span>
    </div>
  </header>

  <!-- Résumé professionnel -->
  <section class="section">
    <h2 class="section-title">Résumé professionnel</h2>
    <p class="summary">
      Développeur logiciel Staff fullstack with {yearsOfExperience}+ ans d'expérience dans la création d'applications évolutives utilisant TypeScript, React, Node.js, and Ruby on Rails. Expertise en intégration IA, architecture de systèmes et direction d'initiatives techniques pour plateformes d'entreprise.
    </p>
  </section>

  <!-- Expérience professionnelle -->
  <section class="section">
    <h2 class="section-title">Expérience professionnelle</h2>
    {experiences.slice(0, 3).map((exp) => (
      <div class="experience-item">
        <div class="experience-header">
          <div class="experience-role">{exp.data.role}</div>
          <div class="experience-date">
            {formatDateShort(exp.data.from, 'fr')} – {exp.data.to ? formatDateShort(exp.data.to, 'fr') : 'Présent'}
            {' '}({formatDuration(exp.data.from, exp.data.to, 'fr')})
          </div>
        </div>
        <div class="experience-company">
          {exp.data.company} {exp.data.remote ? '(Télétravail)' : ''}
        </div>
        {exp.data.location && (
          <div class="experience-location">{exp.data.location}</div>
        )}
        {exp.data.highlights && exp.data.highlights.length > 0 && (
          <div class="experience-highlights">
            <ul>
              {exp.data.highlights.slice(0, 3).map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          </div>
        )}
        {exp.data.stack && exp.data.stack.length > 0 && (
          <div class="experience-stack">
            {exp.data.stack.slice(0, 6).map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        )}
      </div>
    ))}
  </section>

  <!-- Skills -->
  <section class="section">
    <h2 class="section-title">Compétences & expertise</h2>
    <div class="skills-list">
      {[...skills.frontend, ...skills.backend, ...skills.tools, ...skills.ai].join(' • ')}
    </div>
  </section>

  <!-- Education and Languages side by side -->
  <div class="two-col">
    <section class="section">
      <h2 class="section-title">Formation</h2>
      <div class="one-liner">
        Baccalauréat en informatique<br>
        Université de Sherbrooke, 2015
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Langues</h2>
      <div class="one-liner">Anglais (Professionnel) • Français (Natif)</div>
    </section>
  </div>

  <!-- Copyright footer -->
  <footer class="copyright">
    © {currentYear} Lucien Bénié
  </footer>

  <!-- Action buttons - placed at END of body, completely isolated from content -->
  <div class="print-actions">
    <a href="/fr/" class="lang-button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 19l-7-7 7-7m5 14l-7-7 7-7"/>
      </svg>
      Accueil
    </a>
    <div class="print-actions-group">
      <a id="langBtn" href="/en/resume/" class="lang-button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"/>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        EN
      </a>
      <button id="printBtn" class="print-button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
          <rect x="6" y="14" width="12" height="8"/>
        </svg>
        Print to PDF
      </button>
    </div>
  </div>

  <script>
    // Print button functionality
    document.getElementById("printBtn")?.addEventListener("click", () => {
      window.print();
    });

    // Language switcher - preserve ?print=true parameter
    const langBtn = document.getElementById("langBtn");
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("print") === "true" && langBtn) {
      langBtn.setAttribute("href", "/fr/resume/?print=true");
    }

    // Set document title for PDF filename
    document.title = "Lucien-Benie-CV-FR";
  </script>

  <script>
    // Auto-print if ?print=true parameter is present
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("print") === "true") {
      // Wait for page to fully load
      window.addEventListener("load", () => {
        setTimeout(() => {
          window.print();
        }, 500);
      });

      // Close window after printing or canceling
      window.addEventListener("afterprint", () => {
        window.close();
      });
    }
  </script>
</body>
</html>
