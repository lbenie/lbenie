---
import { SITE_CONFIG } from '@utils/seo';
import EmailIcon from '@/components/icons/EmailIcon.astro';
import type { FooterProps } from '@/types/index';

interface Props extends Partial<FooterProps> {}

const { locale = 'en' } = Astro.props;

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    url: SITE_CONFIG.socialLinks?.github,
    label: 'GitHub profile',
  },
  {
    name: 'LinkedIn',
    url: SITE_CONFIG.socialLinks?.linkedin,
    label: 'LinkedIn profile',
  },
  {
    name: 'Email',
    url: `mailto:${SITE_CONFIG.socialLinks?.email}`,
    label: 'Send email',
  },
].filter((link): link is { name: string; url: string; label: string } => !!link.url);

const copyrightText =
  locale === 'fr'
    ? `© ${currentYear} ${SITE_CONFIG.author}. Tous droits réservés.`
    : `© ${currentYear} ${SITE_CONFIG.author}. All rights reserved.`;
---

<footer class="footer" role="contentinfo">
    <div class="footer__container">
        <div class="footer__content">
            <!-- Copyright -->
            <p class="footer__copyright">{copyrightText}</p>

            <!-- Social Links -->
            <div class="footer__social">
                <ul class="footer__social-list">
                    {
                        socialLinks.map((social) => (
                            <li class="footer__social-item">
                                <a
                                    href={social.url}
                                    class="footer__social-link"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={social.label}
                                >
                                    {social.name === 'Email' && <EmailIcon />}
                                    {social.name === 'GitHub' && (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="20"
                                            height="20"
                                            viewBox="0 0 24 24"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                                        </svg>
                                    )}
                                    {social.name === 'LinkedIn' && (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="20"
                                            height="20"
                                            viewBox="0 0 24 24"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zM6.447 20.452H3.694V9h3.554zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                        </svg>
                                    )}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background-color: var(--color-bg-secondary);
        padding: var(--space-md) 0 var(--space-sm);
        margin-top: auto;
    }

    .footer__container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--space-md);
    }

    .footer__content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-lg);
    }

    /* Social Links */
    .footer__social-list {
        display: flex;
        gap: var(--space-sm);
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .footer__social-item {
        margin: 0;
    }

    .footer__social-link {
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color 0.2s ease-in-out;
        display: flex;
        align-items: center;
    }

    .footer__social-link:hover {
        color: var(--color-accent-primary);
    }

    .footer__social-link:focus {
        outline: 2px solid var(--color-border-focus);
        outline-offset: 2px;
        border-radius: var(--radius-sm);
        color: var(--color-accent-primary);
    }

    /* Copyright */
    .footer__copyright {
        color: var(--color-text-secondary);
        font-size: var(--font-size-xs);
        margin: 0;
    }

    @media (max-width: 768px) {
        .footer {
            padding: var(--space-md) 0;
            padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom, 0px));
        }

        .footer__content {
            flex-direction: column;
            align-items: center;
            gap: var(--space-md);
        }
    }
</style>
