{
  "name": "lbenie-portfolio",
  "version": "2.0.0",
  "description": "Bilingual personal portfolio - Lucien Bénié",
  "type": "module",
  "private": true,
  "author": "Lucien Bénié",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18.14.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/generate-og-image.mjs && astro check && astro build && node scripts/generate-cv.mjs",
    "generate:cv": "node scripts/generate-cv.mjs",
    "generate:og": "node scripts/generate-og-image.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check --watch",
    "check:once": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/netlify": "7.0.8",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@microsoft/clarity": "1.0.2",
    "@shikijs/transformers": "4.0.2",
    "astro": "6.3.0",
    "astro-i18next": "1.0.0-beta.21",
    "fuse.js": "7.3.0",
    "i18next": "26.0.8",
    "i18next-fs-backend": "2.6.5",
    "open-props": "1.7.23"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@lbenie/linting": "2.1.14",
    "@types/node": "20.19.39",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "puppeteer": "24.42.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  }
}
