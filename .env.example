# =============================================================================
# Environment Configuration
# =============================================================================
# This file documents all environment variables used in the lbenie portfolio.
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control - it is in .gitignore for security.
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------

# PUBLIC_SITE_URL: The full URL of your deployed site (including protocol)
# Used for: SEO, canonical URLs, OpenGraph tags, RSS feeds
# Example: https://www.lbenie.com
# Required: Yes (for production builds)
PUBLIC_SITE_URL=https://www.lbenie.com

# -----------------------------------------------------------------------------
# Analytics and Tracking
# -----------------------------------------------------------------------------

# PUBLIC_CLARITY_PROJECT_ID: Microsoft Clarity analytics project identifier
# Get your project ID from: https://clarity.microsoft.com
# Navigate to: Your Project > Settings > Overview
# Used for: Session recordings, heatmaps, and user behavior insights
# Required: No (optional - analytics will be disabled if not set)
# Example: abcdef1234
PUBLIC_CLARITY_PROJECT_ID=

# =============================================================================
# Development Notes
# =============================================================================
# - All PUBLIC_* variables are exposed to the client-side code
# - Non-prefixed variables are only available during build time
# - Restart dev server after changing environment variables
# - For Netlify deployment, set these in: Site settings > Environment variables
# =============================================================================
